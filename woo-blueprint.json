        "resource": "literal",
        "name": "schema.sql",
        "contents": "replace into `wpy5_wc_tax_rate_classes` (`tax_rate_class_id`, `name`, `slug`) VALUES ('2', 'Zero rate', 'zero-rate');"
      }
    },
