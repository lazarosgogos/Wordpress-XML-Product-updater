        "resource": "literal",
        "name": "schema.sql",
        "contents": "replace into `wpy5_woocommerce_tax_rates` (`tax_rate_id`, `tax_rate_country`, `tax_rate_state`, `tax_rate`, `tax_rate_name`, `tax_rate_priority`, `tax_rate_compound`, `tax_rate_shipping`, `tax_rate_order`, `tax_rate_class`) VALUES ('1', 'GR', 'B', '24.0000', 'VAT', '1', '0', '1', '0', '');"
